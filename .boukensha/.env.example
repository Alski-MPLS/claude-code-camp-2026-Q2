# Boukensha API keys
# Copy this file to .env and fill in the keys for providers you use.
# You only need keys for the provider configured in settings.yaml.

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (provider: openai)
OPENAI_API_KEY=sk-...

# Google Gemini (provider: gemini)
GEMINI_API_KEY=...

# Ollama Cloud (provider: ollama_cloud)
# Ollama running locally (provider: ollama) needs no key.
OLLAMA_API_KEY=...
