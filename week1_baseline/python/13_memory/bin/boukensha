#!/usr/bin/env python3
"""Entry point for step 13 — mirrors the Ruby bin/boukensha convention."""

from __future__ import annotations

import os
import sys
from pathlib import Path

# Add this step's src/ to the path so boukensha_loader resolves locally.
_HERE = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_HERE / "src"))

# Point at the shared config directory unless the caller already set it.
os.environ.setdefault(
    "BOUKENSHA_DIR",
    str(_HERE.parent.parent.parent / ".boukensha"),
)

from boukensha_loader import load_and_start_repl  # noqa: E402

load_and_start_repl()
